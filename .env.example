NEXT_PUBLIC_SEZNAM_MAPS_API_KEY=6XsRC-7nKjtc7dNqaEv7FN6zPx7u0BcbUBNqmwEk5RM

# Scraper (minutes between scrapes; lower = faster detection but more API load)
# 120 = every 2h, 60 = every hour, 30 = aggressive
SCRAPE_INTERVAL_MINUTES=120

# Scraper region filter (optional, comma-separated region IDs)
# Omit to scrape all 14 regions. "10" = Prague only.
# IDs: 1=Jihočeský, 2=Plzeňský, 3=Karlovarský, 4=Ústecký, 5=Liberecký,
# 6=Královéhradecký, 7=Pardubický, 8=Olomoucký, 9=Zlínský, 10=Praha,
# 11=Středočeský, 12=Moravskoslezský, 13=Vysočina, 14=Jihomoravský
# SCRAPE_REGIONS=10,14
